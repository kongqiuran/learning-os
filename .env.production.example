APP_ENV=production
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=120
LLM_MAX_ATTEMPTS=3

DOCUMENT_INTELLIGENCE_ENABLED=true
VISION_PROVIDER=qwen
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VISION_MODEL=
QWEN_TIMEOUT_SECONDS=120
QWEN_MAX_ATTEMPTS=2
VISION_MAX_PAGES_PER_DOCUMENT=20
DOCUMENT_PAGE_RENDER_DPI=144

DATABASE_URL=sqlite:////data/database/learning_os.db
LEARNING_OS_DATA_DIR=/data

API_SESSION_SECRET=replace_with_at_least_32_random_characters
API_COOKIE_SECURE=true
API_ALLOWED_ORIGINS=https://app.learning-os.cn
ADMIN_EMAILS=admin@example.com
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

MAX_UPLOAD_SIZE_MB=50
ASSISTANT_MAX_CONTEXT_CHARS=16000

OPS_ALERT_WEBHOOK_URL=
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=learning-os
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-guangzhou
